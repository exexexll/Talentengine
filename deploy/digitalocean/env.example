# Copy to `.env` next to docker-compose.yml on the server.
# Never commit real secrets.

# --- Core app ---
# Comma-separated browser origins allowed to call the API with cookies.
# Production: your public https URL. Dev behind Vite: keep localhost ports.
FIGWORK_ALLOWED_ORIGINS=https://app.example.com,http://localhost:3000,http://localhost:8000

# Optional: restrict HTTP Host header (comma-separated). Enable behind a reverse proxy
# that forwards the correct Host, e.g. app.example.com
# FIGWORK_TRUSTED_HOSTS=app.example.com

# --- Internal accounts (optional) ---
# 0 = open API (dev / trusted network). 1 = require login for all /api/*.
FIGWORK_AUTH_ENABLED=0
# openssl rand -hex 32   (must be >= 32 chars when auth is on)
FIGWORK_AUTH_SECRET=
# HTTPS in front (Caddy / DO load balancer) — set 1 so cookies are Secure.
FIGWORK_COOKIE_SECURE=1

# JSON array of users. Prefer password_hash (bcrypt) from:
#   python scripts/hash_figwork_password.py
# Example (single admin, bcrypt — replace HASH with real output):
# FIGWORK_ACCOUNTS_JSON=[{"username":"admin","display_name":"Admin","password_hash":"HASH"}]
#
# Bootstrap-only plain password (rotate to hash before sharing widely):
# FIGWORK_ACCOUNTS_JSON=[{"username":"admin","display_name":"Admin","password":"change-me-first-login"}]
FIGWORK_ACCOUNTS_JSON=[]

# --- Vendor / LLM keys (same as local .env) ---
OPENAI_API_KEY=
SERPAPI_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=
PDL_API_KEY=
WORKTRIGGER_FROM_EMAIL=
# Optional legacy alias accepted by backend:
# RESEND_FROM_EMAIL=
RESEND_API_KEY=
HUBSPOT_PRIVATE_APP_TOKEN=
# LinkedIn automation webhook (optional):
# manual = mark LinkedIn draft sent without external automation
# connect_note = send "Connect + Note" via your webhook provider
# inmail = send InMail via your webhook provider
WORKTRIGGER_LINKEDIN_AUTOMATION_MODE=manual
LINKEDIN_AUTOMATION_WEBHOOK_URL=
LINKEDIN_AUTOMATION_WEBHOOK_TOKEN=
# 1 = after successful email send, also trigger LinkedIn connect+note reminder.
WORKTRIGGER_LINKEDIN_NOTE_AFTER_EMAIL=0
# …add any other keys your deployment uses
