# ─────────────────────────────────────────────────────────────────────────────
# Figwork Geographic Intelligence Engine - Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
#   cp .env.example .env

# ┌───────────────────────────┐
# │  SOURCE MODE              │
# └───────────────────────────┘
# "catalog" = local sample data (default, no API keys needed)
# "live"    = pull from real government APIs (requires keys below)
FIGWORK_SOURCE_MODE=catalog
FIGWORK_SOURCE_RECORDS_FILE=data_pipeline/source_snapshots/local_source_records.json
FIGWORK_LIVE_ALLOW_CATALOG_FALLBACK=1
FIGWORK_LIVE_TIMEOUT_SECONDS=60

# ┌───────────────────────────┐
# │  INFRASTRUCTURE           │
# └───────────────────────────┘
# Redis (optional -- falls back to in-memory TTL cache if not set)
REDIS_URL=
# API base URL for Prefect orchestration tasks
FIGWORK_API_URL=http://localhost:8000

# ┌───────────────────────────────────────────────────────────────────────────┐
# │  API KEYS  (required for FIGWORK_SOURCE_MODE=live)                       │
# │                                                                           │
# │  All keys below are FREE. Registration links:                             │
# │                                                                           │
# │  CENSUS_API_KEY    https://api.census.gov/data/key_signup.html            │
# │                    (covers ACS5, CBP, ZBP, BDS, Pop Estimates)            │
# │                                                                           │
# │  BLS_API_KEY       https://data.bls.gov/registrationEngine/              │
# │                    (covers OEWS, LAUS, QCEW)                              │
# │                                                                           │
# │  BEA_API_KEY       https://apps.bea.gov/API/signup/index.cfm             │
# │                    (covers RPP, GDP)                                       │
# │                                                                           │
# │  ONET_USERNAME     https://services.onetcenter.org/developer/signup       │
# │  ONET_PASSWORD     (same sign-up -- org affiliation required)             │
# │                                                                           │
# │  COLLEGE_SCORECARD_API_KEY                                                │
# │                    https://collegescorecard.ed.gov/data/api/              │
# │                                                                           │
# │  FCC_API_TOKEN     https://broadbandmap.fcc.gov  (create account,         │
# │                    then Manage API Access -> Generate)                     │
# │                                                                           │
# │  IRS / IPEDS / LEHD / RUCA data are published as bulk downloads --        │
# │  no API key needed, just set the download URL.                            │
# └───────────────────────────────────────────────────────────────────────────┘

CENSUS_API_KEY=
BLS_API_KEY=
BEA_API_KEY=
ONET_USERNAME=
ONET_PASSWORD=
COLLEGE_SCORECARD_API_KEY=
FCC_API_TOKEN=

# ┌───────────────────────────────────────────────────────────────────────────┐
# │  LIVE SOURCE URLS                                                         │
# │                                                                           │
# │  These are pre-filled with the official API endpoints. You only need to   │
# │  set the API keys above -- the URLs are ready to go.                      │
# │                                                                           │
# │  TOKEN vars pass as Bearer token in Authorization header. For sources     │
# │  that embed the key in the URL (Census, BLS, BEA), leave TOKEN blank.     │
# └───────────────────────────────────────────────────────────────────────────┘

# --- BLS (OEWS, LAUS, QCEW) ---
# BLS v2 API: pass BLS_API_KEY as registrationkey in body or query param
FIGWORK_LIVE_BLS_OEWS_URL=https://api.bls.gov/publicAPI/v2/timeseries/data/
FIGWORK_LIVE_BLS_OEWS_TOKEN=
FIGWORK_LIVE_BLS_LAUS_URL=https://api.bls.gov/publicAPI/v2/timeseries/data/
FIGWORK_LIVE_BLS_LAUS_TOKEN=
FIGWORK_LIVE_BLS_QCEW_URL=https://data.bls.gov/cew/data/api/
FIGWORK_LIVE_BLS_QCEW_TOKEN=

# --- Census Bureau (ACS5, Pop Estimates, CBP/ZBP, BDS) ---
# Append &key=YOUR_CENSUS_API_KEY to each request
FIGWORK_LIVE_CENSUS_ACS5_URL=https://api.census.gov/data/2023/acs/acs5
FIGWORK_LIVE_CENSUS_ACS5_TOKEN=
FIGWORK_LIVE_CENSUS_POP_ESTIMATES_URL=https://api.census.gov/data/2023/pep/population
FIGWORK_LIVE_CENSUS_POP_ESTIMATES_TOKEN=
FIGWORK_LIVE_CENSUS_CBP_ZBP_URL=https://api.census.gov/data/2022/cbp
FIGWORK_LIVE_CENSUS_CBP_ZBP_TOKEN=
FIGWORK_LIVE_CENSUS_BDS_URL=https://api.census.gov/data/timeseries/bds
FIGWORK_LIVE_CENSUS_BDS_TOKEN=

# --- BEA (RPP, GDP) ---
# Append &UserID=YOUR_BEA_API_KEY to each request
FIGWORK_LIVE_BEA_RPP_URL=https://apps.bea.gov/api/data/?datasetname=Regional&TableName=SARPP&LineCode=1&GeoFIPS=STATE&ResultFormat=json
FIGWORK_LIVE_BEA_RPP_TOKEN=
FIGWORK_LIVE_BEA_GDP_URL=https://apps.bea.gov/api/data/?datasetname=Regional&TableName=SAGDP2N&LineCode=1&GeoFIPS=STATE&ResultFormat=json
FIGWORK_LIVE_BEA_GDP_TOKEN=

# --- LEHD/LODES (Census, bulk CSV -- no key needed) ---
FIGWORK_LIVE_LEHD_LODES_URL=https://lehd.ces.census.gov/data/lodes/LODES8/
FIGWORK_LIVE_LEHD_LODES_TOKEN=

# --- IRS Migration (SOI, bulk CSV -- no key needed) ---
FIGWORK_LIVE_IRS_MIGRATION_URL=https://www.irs.gov/statistics/soi-tax-stats-migration-data
FIGWORK_LIVE_IRS_MIGRATION_TOKEN=

# --- IPEDS (NCES, bulk CSV -- no key needed) ---
FIGWORK_LIVE_NCES_IPEDS_URL=https://nces.ed.gov/ipeds/datacenter/data/
FIGWORK_LIVE_NCES_IPEDS_TOKEN=

# --- College Scorecard (ED.gov API -- uses its own key) ---
FIGWORK_LIVE_COLLEGE_SCORECARD_URL=https://api.data.gov/ed/collegescorecard/v1/schools.json
FIGWORK_LIVE_COLLEGE_SCORECARD_TOKEN=

# --- O*NET (Web Services API -- uses Basic Auth) ---
FIGWORK_LIVE_ONET_URL=https://services.onetcenter.org/ws/
FIGWORK_LIVE_ONET_TOKEN=

# --- FCC Broadband (BDC API -- uses Bearer token) ---
FIGWORK_LIVE_FCC_BROADBAND_URL=https://broadbandmap.fcc.gov/api/public/map
FIGWORK_LIVE_FCC_BROADBAND_TOKEN=

# --- USDA RUCA/RUCC (ERS, bulk download -- no key needed) ---
FIGWORK_LIVE_USDA_RUCA_RUCC_URL=https://www.ers.usda.gov/data-products/rural-urban-commuting-area-codes/
FIGWORK_LIVE_USDA_RUCA_RUCC_TOKEN=
